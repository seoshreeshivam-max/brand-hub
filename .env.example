# ── BrandHub Environment Variables ──

# App Secret
APP_SECRET_KEY=your_secret_key_here

# ── Google OAuth (GSC, GA4, GMC) ───────────────────────
# On Vercel, you will paste the contents of gmail_token.json and client_secret.json here
GOOGLE_TOKEN_JSON='{"token": "...", "refresh_token": "...", ...}'
GOOGLE_CLIENT_SECRET_JSON='{"installed": {"client_id": "...", ...}}'

# ── Global Defaults (if not brand-specific) ────────────
SHOPIFY_STORE=95bd0d.myshopify.com
SHOPIFY_CLIENT_ID=...
SHOPIFY_CLIENT_SECRET=...

# ── Brand: Shree Shivam ───────────────────────────────
SHREESHIVAM_SHOPIFY_STORE=95bd0d.myshopify.com
SHREESHIVAM_SHOPIFY_CLIENT_ID=...
SHREESHIVAM_SHOPIFY_CLIENT_SECRET=...

# ── Brand: White Hanger ───────────────────────────────
WHITEHANGER_SHOPIFY_STORE=whitehanger-fashion.myshopify.com
WHITEHANGER_SHOPIFY_CLIENT_ID=...
WHITEHANGER_SHOPIFY_CLIENT_SECRET=...

# ── Brand: Amchoor ───────────────────────────────────────
AMCHOOR_SHOPIFY_STORE=amchoor-official.myshopify.com
AMCHOOR_SHOPIFY_CLIENT_ID=...
AMCHOOR_SHOPIFY_CLIENT_SECRET=...

# ── External APIs ─────────────────────────────────────
DATAFORSEO_LOGIN=...
DATAFORSEO_PASSWORD=...
SERPER_API_KEY=...
NVIDIA_API_KEY=...
GEMINI_API_KEY=...
